generator client {
  provider = "prisma-client"
  runtime  = "cloudflare"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  YOUTUBE
  TWITTER
  ARTICLE
  DOCUMENT
}

enum ContentStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  googleId String? @unique

  contents Content[]
  links    Link[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Content {
  id String @id @default(cuid())

  title       String
  description String?

  link String
  type ContentType

  searchableText String?

  embedding Unsupported("vector(768)")?

  imageUrl    String?
  siteName    String?
  author      String?
  publishedAt DateTime?

  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status ContentStatus @default(PROCESSING)
  tags   Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, title])
}

model Tag {
  id    String @id @default(cuid())
  title String @unique

  contents Content[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Link {
  id   String @id @default(cuid())
  hash String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
